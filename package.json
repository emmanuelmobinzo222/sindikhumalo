/**
 * KOTA PAL Package Configuration
 * Dependencies required for the multi-retailer integration system
 */

{
  "name": "kota-pal-realtime",
  "version": "2.0.0",
  "description": "KOTA PAL - Real-time multi-retailer affiliate platform with advanced analytics",
  "main": "backend-enhanced.js",
  "scripts": {
    "start": "node backend-enhanced.js",
    "dev": "nodemon backend-enhanced.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "docker:build": "docker build -t kota-pal:latest .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f backend",
    "migrate:db": "node scripts/migrate.js",
    "seed:db": "node scripts/seed.js"
  },
  "keywords": [
    "affiliate-marketing",
    "retailer-integration",
    "real-time-analytics",
    "content-creator",
    "multi-retailer",
    "websocket",
    "redis"
  ],
  "author": "KOTA PAL Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "bcrypt": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "dotenv": "^16.3.1",
    "redis": "^4.6.12",
    "bull": "^4.11.4",
    "node-cache": "^5.1.2",
    "ws": "^8.14.2",
    "axios": "^1.6.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "rate-limit": "^0.2.0",
    "express-rate-limit": "^7.0.0",
    "pino": "^8.16.2",
    "pino-http": "^8.5.0",
    "pg": "^8.11.3",
    "sequelize": "^6.35.1",
    "joi": "^17.11.0",
    "lodash": "^4.17.21",
    "firebase": "^10.7.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.53.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "@faker-js/faker": "^8.3.1"
  }
}
